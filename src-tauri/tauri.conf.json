{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "벼넥시트",
  "version": "0.1.3",
  "identifier": "com.imsorasongy.lawyer-game",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "벼넥시트",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 imsorasongy",
    "shortDescription": "벼넥시트 — 전설적 변호사의 탄생",
    "longDescription": "10년간의 변호사 시뮬레이션. 사건을 해결하고 신분을 올리며 자신만의 커리어를 만들어가는 경영·롤플레잉 게임."
  }
}
